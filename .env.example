# ──────────────────────────────────────────────────────────────────────────
# whatsapp-gateway — Beispiel-Konfiguration
# Kopieren nach `.env` und mit echten Werten füllen. `.env` NICHT einchecken.
# ──────────────────────────────────────────────────────────────────────────

# --- Server ---
SERVER_PORT=8080

# --- WhatsApp Cloud API (Meta) ---
# Frei gewähltes Geheimwort, identisch zum Wert im Meta App Dashboard (Webhook).
WHATSAPP_VERIFY_TOKEN=change-me-verify-token
# App-Secret aus dem Meta App Dashboard (Settings -> Basic). Für HMAC-Signaturprüfung.
WHATSAPP_APP_SECRET=change-me-app-secret
WHATSAPP_GRAPH_API_VERSION=v25.0
WHATSAPP_GRAPH_API_BASE_URL=https://graph.facebook.com

# --- Datenbank (PostgreSQL) ---
# Innerhalb von docker-compose ist der Host der Service-Name `db`.
DB_URL=jdbc:postgresql://db:5432/whatsappgateway
DB_USERNAME=whatsappgateway
DB_PASSWORD=change-me-db-password

# --- Admin-Schutz der /api/**-Endpoints ---
# Bei jedem Verwaltungs-Request als Header `X-Admin-Api-Key` mitschicken.
ADMIN_API_KEY=change-me-admin-key

# --- Verschlüsselung der gespeicherten Access-Tokens (AES-256-GCM) ---
# Base64-kodierter 32-Byte-Schlüssel. Erzeugen z. B. mit:
#   openssl rand -base64 32
APP_ENCRYPTION_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=

# --- Reverse Proxy (bestehender Caddy-Container auf dem Server) ---
# Das bestehende Caddy-Netzwerk ist in der docker-compose.yml fest als `proxy`
# (external) verdrahtet (Hausstil, identisch zu den anderen Stacks auf dem Server).
# Heisst das Caddy-Netz auf dem Server anders, in der docker-compose.yml den Namen
# `proxy` anpassen (an den Services UND im networks-Block). Ermitteln z. B. mit
# `docker network ls`. Es ist hier KEINE Env-Variable noetig.

# Optionaler Name der PostgreSQL-Datenbank (Default: whatsappgateway).
# Muss zu DB_URL passen.
DB_NAME=whatsappgateway
